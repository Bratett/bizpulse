{
  "realm": "bizpulse",
  "enabled": true,
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "sslRequired": "none",
  "accessTokenLifespan": 86400,
  "refreshTokenMaxReuse": 0,
  "ssoSessionMaxLifespan": 2592000,
  "roles": {
    "realm": [
      { "name": "owner", "description": "Business owner — full access" },
      { "name": "admin", "description": "Business admin — manage users and settings" },
      { "name": "member", "description": "Team member — read/write transactions" },
      { "name": "viewer", "description": "Read-only access to reports" }
    ]
  },
  "defaultRoles": ["member"],
  "clients": [
    {
      "clientId": "web-app",
      "name": "BizPulse Web App",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "rootUrl": "http://localhost:3000",
      "baseUrl": "/",
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost:8000/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://localhost:8000"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "business_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "business_id",
            "claim.name": "business_id",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "jsonType.label": "String"
          }
        },
        {
          "name": "realm_roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "roles",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "clientId": "mobile-app",
      "name": "BizPulse Mobile App",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": ["bizpulse://*"],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "business_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "business_id",
            "claim.name": "business_id",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "clientId": "service-account",
      "name": "BizPulse Service Account",
      "enabled": true,
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": false,
      "secret": "service-account-secret-change-in-production",
      "protocolMappers": [
        {
          "name": "business_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "business_id",
            "claim.name": "business_id",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "demo@bizpulse.ai",
      "email": "demo@bizpulse.ai",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Demo",
      "lastName": "User",
      "attributes": {
        "business_id": ["00000000-0000-0000-0000-000000000001"]
      },
      "credentials": [
        {
          "type": "password",
          "value": "demo1234",
          "temporary": false
        }
      ],
      "realmRoles": ["owner"]
    }
  ]
}
